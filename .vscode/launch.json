{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dashboard (Streamlit)",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "pulseengine/local/dashboard.py"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Scan (Dry Run)",
            "type": "debugpy",
            "request": "launch",
            "module": "app.scan",
            "args": [
                "--dry-run"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Scan (Full)",
            "type": "debugpy",
            "request": "launch",
            "module": "app.scan",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Analysis CLI",
            "type": "debugpy",
            "request": "launch",
            "module": "app.analysis",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Tests (pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "-v",
                "--tb=short"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}
